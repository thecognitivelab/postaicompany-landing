# ─── Video Clips (D-ID) ──────────────────────────────────────────────────────
# D_ID_AUTH_FILE=~/.d-id-auth          # path to file with base64 Basic auth token
# D_ID_AUTH=<base64-email:api-key>     # or set directly (used in GitHub Actions)

# ─── SEO ─────────────────────────────────────────────────────────────────────
# GSC_API_KEY=                         # Google Search Console Indexing API key

