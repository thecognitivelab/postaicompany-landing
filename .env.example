# Copy to .env (local) or set in Vercel project settings. Never commit real values.

# Resend — required for /api/subscribe and /api/contact
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: audience id for the subscribe endpoint. If unset, emails are logged only.
RESEND_AUDIENCE_ID=
# Optional overrides (defaults shown)
# FROM_EMAIL=Post AI Company <hello@postaicompany.com>
# CONTACT_TO_EMAIL=fefaria@syntheticperson.ai

# Local dev server port (default 9090)
# PORT=9090

# Content generation scripts (optional, only for scripts/)
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx
# Path to a file containing your D-ID Basic auth token (default: ~/.d-id-auth)
# D_ID_AUTH_FILE=/path/to/.d-id-auth
